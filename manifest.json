{
  "manifest_version": 3,
  "name": "DuoGPT Beta",
  "version": "2.4.1",
  "description": "AI Copilot providing structured explanations and tools for Duolingo lessons.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.duolingo.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.duolingo.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "sidepanel.css", "sidepanel.js", "libs/marked.min.js"],
      "matches": ["https://www.duolingo.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
