{
  "manifest_version": 3,
  "name": "DuoGPT Beta",
  "version": "2.0.5",
  "description": "AI Help for Duolingo lessons",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.duolingo.com/*",
    "https://generativelanguage.googleapis.com/*"
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.duolingo.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [{

    "resources": ["sidepanel.html", "sidepanel.css", "sidepanel.js", "libs/marked.min.js"],

    "matches": ["https://www.duolingo.com/*"]

  }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
